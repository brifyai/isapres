# Puerto del servidor
PORT=3000

# CORS origin (URL del frontend)
CORS_ORIGIN=http://localhost:5173

# URL publica del frontend
PUBLIC_APP_URL=http://localhost:5173

# Conexion principal a Postgres/Supabase
DATABASE_URL=postgresql://postgres.tu-proyecto:tu-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# JWT Secret (cambiar en producción)
JWT_SECRET=wsp-isap-dev-secret-change-in-production

# Clave de cifrado AES-256 para credenciales (cambiar en producción)
ENCRYPTION_KEY=wsp-isap-dev-key-change-in-production-32b!

# Clave de admin para endpoints administrativos
ADMIN_KEY=wsp-isap-admin-dev-key

# Proyecto Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
SUPABASE_STORAGE_BUCKET_REEMBOLSOS=reembolsos
