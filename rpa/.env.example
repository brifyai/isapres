# Conexion principal a Postgres/Supabase
DATABASE_URL=postgresql://postgres.tu-proyecto:tu-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Clave de cifrado AES-256 (debe ser igual que el backend)
ENCRYPTION_KEY=wsp-isap-dev-key-change-in-production-32b!

# Modo headless (true = sin UI, false = ver navegador)
HEADLESS=true

# Identificador del worker para trazabilidad futura
RPA_WORKER_ID=rpa-local-01

# Puerto del healthcheck HTTP del worker
RPA_HEALTH_PORT=3210

# Proyecto Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
SUPABASE_STORAGE_BUCKET_REEMBOLSOS=reembolsos
